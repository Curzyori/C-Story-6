---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
  title = "C Story | Interactive Storyboard Engine", 
  description = "An interactive storyboard engine prioritizing performance, security, and clean, modular code." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-deep-dark text-white font-sans antialiased min-h-screen">
    <div class="relative flex flex-col min-h-screen">
      <!-- Background Glow / Accent Elements -->
      <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-neon-green/10 blur-[120px] rounded-full"></div>
      </div>

      <!-- Main Layout -->
      <header class="relative z-10 p-6 border-b border-white/5 backdrop-blur-md bg-deep-dark/80">
        <nav class="max-w-7xl mx-auto flex justify-between items-center">
          <a href="/" class="text-2xl font-bold tracking-tighter text-neon-green">
            C <span class="text-white">Story</span>
          </a>
        </nav>
      </header>

      <main class="relative z-10 flex-grow max-w-7xl w-full mx-auto p-6">
        <slot />
      </main>

      <footer class="relative z-10 p-6 border-t border-white/5 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} Curzy Ecosystem. All rights reserved.
      </footer>
    </div>
	</body>
</html>
