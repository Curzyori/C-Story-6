---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="C Story | Home">
  <section class="flex flex-col items-center justify-center min-h-[60vh] text-center space-y-6">
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight">
      Welcome to <span class="text-neon-green">C Story</span>
    </h1>
    
    <p class="text-lg md:text-xl text-gray-400 max-w-2xl">
      The 6th project in the Curzy Ecosystem. An interactive storyboard engine built for performance, security, and a premium visual experience.
    </p>

    <div class="flex flex-wrap justify-center gap-4 mt-8">
      <a href="/story" class="px-8 py-3 rounded-full bg-neon-green text-deep-dark font-semibold hover:bg-emerald-400 transition-colors shadow-[0_0_20px_rgba(16,185,129,0.3)]">
        Start Engine
      </a>
      <button id="reset-progress" class="px-8 py-3 rounded-full border border-white/10 hover:bg-red-500/10 hover:border-red-500/30 transition-all text-gray-400 hover:text-red-500">
        Reset Progress
      </button>
      <a href="https://github.com/Curzyori" class="px-8 py-3 rounded-full border border-white/10 hover:bg-white/5 transition-colors">
        Curzy Hub
      </a>
    </div>

    <script>
      const resetBtn = document.getElementById('reset-progress');
      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          if (confirm("Reset all story progress? This cannot be undone.")) {
            localStorage.removeItem('curzy_cstory_save');
            alert("System state wiped. Ready for fresh initialization.");
          }
        });
      }
    </script>
  </section>
</MainLayout>
